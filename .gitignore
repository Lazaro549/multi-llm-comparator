```gitignore
# =========================
# 🐍 Python
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so

# Virtual environments
venv/
.env/
.env.*

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# =========================
# 🌐 Node / Next.js
# =========================
node_modules/
.next/
out/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# ⚙️ Environment variables
# =========================
.env
.env.local
.env.development
.env.test
.env.production

# =========================
# 🧪 Testing
# =========================
.pytest_cache/
coverage/
htmlcov/

# =========================
# 🖥️ OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# 🧠 IDEs / Editors
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# 🚀 Misc
# =========================
*.sqlite3
*.db

# Temporary files
tmp/
temp/
```
